@using DIGESA.Models.Entities.DIGESA
@page "/TratamientoCannabis"
@using MudBlazor

<MudCard>
    <MudCardHeader Title="Tratamiento Prescrito (Cannabis)" />
    <MudCardContent>
        <MudTextField Label="Nombre Genérico" T="string" @bind-Value="Tratamiento.NombreGenericoProducto" />
        <MudTextField Label="Nombre Comercial" T="string" @bind-Value="Tratamiento.NombreComercialProducto" />
        <MudTextField Label="Forma Farmacéutica" T="string" @bind-Value="Tratamiento.FormaFarmaceutica" />
        
        <MudNumericField Label="Concentración CBD (mg/ml)" T="decimal" @bind-Value="Tratamiento.ConcentracionCbd" />
        <MudNumericField Label="Concentración THC (mg/ml)" T="decimal" @bind-Value="Tratamiento.ConcentracionThc" />
        <MudTextField Label="Otros Cannabinoides" T="string" @bind-Value="Tratamiento.OtrosCannabinoides" />

        <MudSelect Label="Vía de Administración" T="string" @bind-Value="Tratamiento.ViaAdministracion">
            @foreach (var via in new[] { "Oral", "Sublingual", "Inhalada" })
            {
                <MudSelectItem Value="@via">@via</MudSelectItem>
            }
        </MudSelect>

        <MudTextField Label="Dosis" T="string" @bind-Value="Tratamiento.Dosis" />
        <MudTextField Label="Frecuencia" T="string" @bind-Value="Tratamiento.FrecuenciaAdministracion" />
        <MudNumericField Label="Duración (días)" T="int" @bind-Value="Tratamiento.DuracionTratamientoDias" />
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public Tratamiento Tratamiento { get; set; }
}