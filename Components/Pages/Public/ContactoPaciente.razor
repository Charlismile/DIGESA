@using DIGESA.Models.Entities.DIGESA
@page "/ContactoPaciente"
@using MudBlazor

<MudCard>
    <MudCardHeader Title="Datos de Contacto" />
    <MudCardContent>
        <MudTextField Label="Teléfono Personal" T="string" @bind-Value="Paciente.TelefonoPersonal" />
        <MudTextField Label="Teléfono Residencial" T="string" @bind-Value="Paciente.TelefonoResidencial" />
        <MudTextField Label="Teléfono Laboral" T="string" @bind-Value="Paciente.TelefonoLaboral" />
        <MudTextField Label="Correo Electrónico" T="string" @bind-Value="Paciente.CorreoElectronico" />
        <MudTextField Label="Dirección Residencial" T="string" @bind-Value="Paciente.DireccionResidencia" />
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public Paciente Paciente { get; set; }
}
