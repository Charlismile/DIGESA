@using DIGESA.Models.Entities.DIGESA
@page "/CentroSalud"
@using MudBlazor

<MudCard>
    <MudCardHeader Title="Centro de Atención" />
    <MudCardContent>
        <MudTextField Label="Instalación de Salud" T="string" @bind-Value="Paciente.InstalacionSalud" />
        <MudTextField Label="Región de Salud" T="string" @bind-Value="Paciente.RegionSalud" />
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public Paciente Paciente { get; set; }
}