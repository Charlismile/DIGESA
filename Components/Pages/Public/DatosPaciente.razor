@using DIGESA.Models.Entities.DIGESA
@using MudBlazor

<MudCard>
    <MudCardHeader Title="Información del Paciente" />
    <MudCardContent>
        <MudTextField Label="Nombre Completo" T="string" Required="true" @bind-Value="Paciente.NombreCompleto" />
        <MudSelect Label="Tipo de Documento" T="string" @bind-Value="Paciente.TipoDocumento">
            @foreach (var tipo in new[] {"Cédula", "Pasaporte" })
            {
                <MudSelectItem Value="@tipo">@tipo</MudSelectItem>
            }
        </MudSelect>
        <MudTextField Label="Número de Documento" T="string" Required="true" @bind-Value="Paciente.NumeroDocumento" />
        <MudTextField Label="Nacionalidad" T="string" @bind-Value="Paciente.Nacionalidad" />
        <MudDatePicker Label="Fecha de Nacimiento" @bind-Value="Paciente.FechaNacimiento" />
        <MudRadioGroup Label="Sexo" T="string" @bind-Value="Paciente.Sexo">
            @foreach (var sexo in new[] { "Masculino", "Femenino", "Otro" })
            {
                <MudRadio Value="@sexo">@sexo</MudRadio>
            }
        </MudRadioGroup>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public Paciente Paciente { get; set; }
}
