@using DIGESA.Models.Entities.DIGESA
@page "/InformacionMedica"
@using MudBlazor
@inject ISnackbar Snackbar


<MudCard>
    <MudCardHeader Title="Información Médica" />
    <MudCardContent>
        <MudSelect Label="Diagnóstico Principal" T="string" @bind-Value="Solicitud.DiagnosticoPrincipal">
            @foreach (var diagnostico in DiagnosticosDisponibles)
            {
                <MudSelectItem Value="@diagnostico.Nombre">@diagnostico.Nombre</MudSelectItem>
            }
        </MudSelect>
        
        <MudTextField Label="Motivo Médico" T="string" Required="true" @bind-Value="Solicitud.MotivoSolicitud" />

        <MudFileUpload Label="Adjuntar Documentos" AcceptedFileTypes=".pdf,.jpg,.png" />
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public Solicitud Solicitud { get; set; }
    [Parameter] public List<Diagnostico> DiagnosticosDisponibles { get; set; }
}