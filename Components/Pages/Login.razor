@page "/login"
@using System.Security.Claims
@using DIGESA.Models.Entities.DIGESA
@using DIGESA.Services
@using Microsoft.AspNetCore.Authentication
@using Models
@inject NavigationManager NavManager
@inject HttpClient Http
@inject AuthService AuthService
@inject IHttpContextAccessor HttpContextAccessor

<h3>Iniciar Sesión</h3>

<EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
    <InputText @bind-Value="loginModel.Email" placeholder="Correo" />
    <InputText @bind-Value="loginModel.Contraseña" placeholder="Contraseña" type="password" />
    <button type="submit">Iniciar sesión</button>
</EditForm>

@code {
    private LoginModel loginModel = new();

    private async Task HandleLogin()
    {
        // Aquí deberías hacer una llamada al backend para validar credenciales
        var usuario = await Http.GetFromJsonAsync<Usuario>(
            $"api/usuarios?email={loginModel.Email}&contraseña={loginModel.Contraseña}");

        if (usuario != null)
        {
            var claims = new List<Claim>
            {
                new Claim(ClaimTypes.Email, usuario.Email),
                new Claim(ClaimTypes.Role, usuario.Rol)
            };

            var identity = new ClaimsIdentity(claims, "custom");
            var user = new ClaimsPrincipal(identity);

            var context = HttpContextAccessor.HttpContext;
            await context.SignInAsync("CustomAuth", user);

            NavManager.NavigateTo("/dashboard");
        }
        else
        {
            // Mostrar mensaje de error
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Contraseña { get; set; } = string.Empty;
    }
}