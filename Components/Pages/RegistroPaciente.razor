@page "/registro"
@using DIGESA.Models.Entities.DIGESA
@inject NavigationManager NavManager
@inject IEmailService EmailService

<PageTitle>Registro de Paciente - Cannabis Medicinal</PageTitle>

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Formulario de Registro</h4>
        </div>
        <div class="card-body">

            <EditForm Model="@paciente" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <!-- Datos Personales -->
                <h5 class="mt-4 mb-3">1. Datos Personales del Paciente</h5>
                <div class="row">
                    <div class="col-md-6">
                        <label>1.1 Nombre completo del paciente</label>
                        <InputText @bind-Value="paciente.NombreCompleto" class="form-control" />
                        <ValidationMessage For="@(() => paciente.NombreCompleto)" />
                    </div>
                    <div class="col-md-6">
                        <label>1.2 Documento de identidad</label>
                        <InputSelect @bind-Value="paciente.TipoDocumento">
                            <option value="">Seleccionar</option>
                            <option value="Cedula">Cédula</option>
                            <option value="Pasaporte">Pasaporte</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <label>1.2.1 Número del documento</label>
                        <InputText @bind-Value="paciente.NumeroDocumento" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>1.3 Nacionalidad</label>
                        <InputText @bind-Value="paciente.Nacionalidad" class="form-control" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <label>1.4 Fecha de nacimiento</label>
                        <InputDate @bind-Value="paciente.FechaNacimiento" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label>1.5 Sexo</label>
                        <InputSelect @bind-Value="paciente.Sexo">
                            <option value="">Seleccionar</option>
                            <option value="Femenino">Femenino</option>
                            <option value="Masculino">Masculino</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label>1.6 Residencia</label>
                        <InputText @bind-Value="paciente.Residencia" class="form-control" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <label>1.7 Teléfono residencial</label>
                        <InputText @bind-Value="paciente.TelefonoResidencial" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label>Teléfono personal</label>
                        <InputText @bind-Value="paciente.TelefonoPersonal" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label>Teléfono laboral</label>
                        <InputText @bind-Value="paciente.TelefonoLaboral" class="form-control" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <label>Correo electrónico</label>
                        <InputText @bind-Value="paciente.CorreoElectronico" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>1.9 Instalación de salud donde es atendido</label>
                        <InputText @bind-Value="paciente.InstalacionSalud" class="form-control" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <label>1.9.1 Región de salud</label>
                        <InputText @bind-Value="paciente.RegionSalud" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label>1.10 ¿Requiere acompañante autorizado?</label>
                        <InputCheckbox @bind-Value="paciente.RequiereAcompanante" />
                    </div>
                </div>

                @if (paciente.RequiereAcompanante)
                {
                    <h5 class="mt-4 mb-3">2. Datos del Acompañante Autorizado</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <label>Nombre completo del acompañante</label>
                            <InputText @bind-Value="paciente.Acompanante.NombreCompleto" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label>Tipo de documento</label>
                            <InputSelect @bind-Value="paciente.Acompanante.TipoDocumento">
                                <option value="Cedula">Cédula</option>
                                <option value="Pasaporte">Pasaporte</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-3">
                            <label>Número del documento</label>
                            <InputText @bind-Value="paciente.Acompanante.NumeroDocumento" class="form-control" />
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label>Nacionalidad</label>
                            <InputText @bind-Value="paciente.Acompanante.Nacionalidad" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label>Parentesco con el paciente</label>
                            <InputText @bind-Value="paciente.Acompanante.Parentesco" class="form-control" />
                        </div>
                    </div>
                }

                <button type="submit" class="btn btn-success mt-4">Enviar Solicitud</button>
            </EditForm>

            @if (mostrarMensaje)
            {
                <div class="alert alert-success mt-3">
                    Su solicitud fue enviada y será procesada en 7 días hábiles.
                </div>
            }

        </div>
    </div>
</div>

@code {
    private Paciente paciente = new()
    {
        Acompanante = new Acompanante()
    };
    private bool mostrarMensaje;

    private async Task HandleValidSubmit()
    {
        // Aquí puedes hacer el POST a tu API o guardar en BD
        mostrarMensaje = true;

        // Enviar correo de confirmación
        var body = $"<h3>Su solicitud fue recibida</h3><p>Hola {paciente.NombreCompleto}, su solicitud fue enviada exitosamente.</p>";
        await EmailService.SendEmailAsync(paciente.CorreoElectronico, "Solicitud Recibida", body);
    }
}