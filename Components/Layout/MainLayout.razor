@using MudBlazor
@inherits LayoutComponentBase

<div class="page">
    <div class="container-fluid">
        <img alt="image" src="logo-gob.png" width="300"/>
        <NavMenu/>
    </div>
</div>
<div class="container">
    <div>
        @* Required *@
        <MudThemeProvider />
        <MudPopoverProvider />

        @* Needed for dialogs *@
        <MudDialogProvider />

        @* Needed for snackbars *@
        <MudSnackbarProvider />
        <article class="content px-4">
            @Body
        </article>
    </div>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>