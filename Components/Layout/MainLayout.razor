@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar>
        DIGESA
        <MudImage Src="/logo-minsa.png" Alt="logo minsa" Width="35"/>
        <MudSpacer />
    </MudAppBar>
    <MudMainContent MaxWidth="MaxWidth.ExtraLarge">
        <MudImage Src="/logo-gob.png" Alt="logogob" Width="300" Class="rounded-lg ma-4" FallbackSrc="/logo-minsa.png"/>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}